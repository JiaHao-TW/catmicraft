{
  "name": "catmicraft",
  "version": "1.0.0",
  "description": "Catmi Craft - Vue 3 + MongoDB 應用",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:api\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:api": "cd api && go run main.go",
    "build": "npm run build:frontend && npm run build:api ",
    "build:frontend": "cd frontend && npm run build",
    "build:api": "cd api && go build -o catmicraft-api main.go",
    "preview": "cd frontend && npm run preview"
   },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
